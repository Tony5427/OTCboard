	(text "Output Voltage\nVout = Vq+B*(Sensitivity*(1+Stc*(Tambient-25C)))\nVq=VCC/2=3.3/2=1.65\nB=75Gs - 640 Gs = 7.5mT - 64mT\nSensitivity = 15 mV/mT\nStc = 0.0012 or 0.12%\nTambient = 25C\nVout = 1.765V - 2.639V\nRipple = 3mVpp (datasheet)\n\nFilter:\nFc=1/(2piRC)\nR=1000ohm, F=1Hz\nC=1/(2piRF)=0.1667uF\njust use C=0.luF -> F=1592Hz"
		(exclude_from_sim no)
		(at 158.75 91.44 0)
